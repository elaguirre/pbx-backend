APP_NAME="PBX API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://pbx-back.test
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_DEFAULT_TIMEZONE_USER=America/Mexico_City

TENANCY_DB_SUFFIX=_production
# Requires CREATE/DROP on tenant databases (usually root). Keep false with limited DB users.
TENANCY_DROP_DATABASE_BEFORE_CREATE=false

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pbx_central
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@pbx.local"
MAIL_FROM_NAME="${APP_NAME}"
